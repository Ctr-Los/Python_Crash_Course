age_0 >= 21 or age_1 >=21 #Despite only one of them being false, as long as the other one is true then the whole thing is true. 

age_0 = 18

age_0 >= 21 or age_1>21 #Here both are false, therefore the whole thing is false. 

#Checking whether a value is in a list. 

#If you ever want to check if there is a specific value in a list you can use the keyword "in"

#This is great when you need to see if there is a username avaliable when signing someone up. 

#Here is an example:

requested_toppings = ['mushrooms','onions','pineapple']

'mushrooms' in requested_toppings #This comes out to be true because there is a value called mushrooms in the list. 

#Here is one where is NOT in the list 

requested_toppings = ['mushrooms','onions','pineapples']
'pepperoni' in requested_toppings #Pepperoni is NOT in the list, therefore it is false. 

#Check whether a value is NOT in a list. 

#If you ever want to know a value does not appear in a list. 
#Using the keyword 'not' can help. 
#This is great when, seeing if a user has been banned before reinstating them. 

banned_users = ['andrew','carolina','david']
user = 'marie'

if user not in banned_users: #Here we are checking if marie is not in the banned list, which she is not, therefore she can respond. 
  print(user.title()+ ', you can post a response if you wish')

